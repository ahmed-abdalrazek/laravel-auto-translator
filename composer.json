{
    "name": "aar/laravel-auto-translator",
    "description": "A comprehensive, high-performance translation management system for Laravel with AI translation, dashboard UI, and CLI tools.",
    "keywords": ["laravel", "translation", "i18n", "localization", "ai", "tailwind", "alpine"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Ahmed Abdalrazek",
            "email": "ahmed.abdalrazek@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/view": "^10.0|^11.0|^12.0",
        "symfony/finder": "^6.0|^7.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Aar\\AutoTranslator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aar\\AutoTranslator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aar\\AutoTranslator\\AarTranslatorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
